@page "/history"
@inject IApiClient Api

<h4 class="mb-3">Expense History</h4>

@if (_users is not null)
{
    <div class="mb-3">
        <div class="btn-group btn-group-sm">
            <button class="btn @(_filterPaidById is null ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => FilterBy(null)">All</button>
            @foreach (var user in _users)
            {
                <button class="btn @(_filterPaidById == user.Id ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => FilterBy(user.Id)">@user.Name</button>
            }
        </div>
    </div>
}

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border"></div>
    </div>
}
else if (_expenses.Count == 0)
{
    <p class="text-muted">No expenses found.</p>
}
else
{
    @foreach (var expense in _expenses)
    {
        <ExpenseCard Expense="expense" />
    }

    @if (_totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(_page <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(_page - 1)">Previous</button>
                </li>
                @for (int i = 1; i <= _totalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(_page == pageNum ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(_page + 1)">Next</button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private const int PageSize = 20;
    private List<UserDto>? _users;
    private List<ExpenseDto> _expenses = [];
    private bool _loading = true;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages;
    private int? _filterPaidById;

    protected override async Task OnInitializedAsync()
    {
        _users = await Api.GetUsersAsync();
        await LoadExpenses();
    }

    private async Task LoadExpenses()
    {
        _loading = true;
        var result = await Api.GetExpensesAsync(_page, PageSize, _filterPaidById);
        _expenses = result.Items.ToList();
        _totalCount = result.TotalCount;
        _totalPages = (int)Math.Ceiling((double)_totalCount / PageSize);
        _loading = false;
    }

    private async Task FilterBy(int? userId)
    {
        _filterPaidById = userId;
        _page = 1;
        await LoadExpenses();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _page = page;
        await LoadExpenses();
    }
}
