@page "/"
@inject IApiClient Api
@inject NavigationManager Nav

<h4 class="mb-3">Dashboard</h4>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border"></div>
    </div>
}
else
{
    <BalanceSummary Balance="_balance" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Recent Expenses</h5>
        <a href="/add" class="btn btn-primary btn-sm">+ Add Expense</a>
    </div>

    @if (_expenses.Count == 0)
    {
        <p class="text-muted">No expenses yet. Add your first one!</p>
    }
    else
    {
        @foreach (var expense in _expenses)
        {
            <ExpenseCard Expense="expense" />
        }

        @if (_totalCount > 5)
        {
            <div class="text-center mt-2">
                <a href="/history" class="btn btn-outline-secondary btn-sm">View all @_totalCount expenses</a>
            </div>
        }
    }
}

@code {
    private bool _loading = true;
    private BalanceDto? _balance;
    private List<ExpenseDto> _expenses = [];
    private int _totalCount;

    protected override async Task OnInitializedAsync()
    {
        var balanceTask = Api.GetBalanceAsync();
        var expensesTask = Api.GetExpensesAsync(1, 5);

        _balance = await balanceTask;
        var result = await expensesTask;
        _expenses = result.Items.ToList();
        _totalCount = result.TotalCount;
        _loading = false;
    }
}
